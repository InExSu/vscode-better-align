{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2020",
		"lib"   : [
			"ES2020"
		],
		"types": ["node", "mocha", "glob"],
		"strictPropertyInitialization": false,
		"sourceMap": true,
			"strict": true,
			"rootDir": ".",
			"outDir": "out"
	},
	"include": [
		"src/**/*.ts",
		"test/**/*.ts"
	],
	"exclude": []
}